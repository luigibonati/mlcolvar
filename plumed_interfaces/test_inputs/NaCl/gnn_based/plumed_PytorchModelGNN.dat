# vim:ft=plumed

UNITS LENGTH=A

# load interface for GNNs
LOAD FILE=PytorchModelGNN.cpp

# use molinfo to select atoms (optional but recommended)
MOLINFO STRUCTURE=NaCl.pdb PYTHON_BIN=/path/to/python/with/mdtraj
GROUP ATOMS={@mdt:{type Na or type Cl}} LABEL=sys
GROUP ATOMS={@mdt:{type O}} LABEL=env

O: GROUP ATOMS=1,4,7,10,13,16,19,22,25,28,31,34,37,40,43,46,49,52,55,58,61,64,67,70,73,76,79,82,85,88,91,94,97,100,103,106,109,112,115,118,121,124,127,130,133,136,139,142,145,148,151,154,157,160,163,166,169,172,175,178,181,184,187,190,193,196,199,202,205,208,211,214,217,220,223,226,229,232,235,238,241,244,247,250,253,256,259,262,265,268,271,274,277,280,283,286,289,292,295,298,301,304,307,310,313,316,319,322,325,328,331,334,337,340,343,346,349,352,355,358,361,364,367,370,373,376,379,382,385,388,391,394,397,400,403,406,409,412,415,418,421,424,427,430,433,436,439,442,445,448,451,454,457,460,463,466,469,472,475,478,481,484,487,490,493,496,499,502,505,508,511,514,517,520,523,526,529,532,535,538,541,544,547,550,553,556,559,562,565,568,571,574,577,580,583,586,589,592,595,598,601,604,607,610,613,616,619,622,625,628,631,634,637,640,643,646
Na: GROUP ATOMS=649
Cl: GROUP ATOMS=650

dist: DISTANCE ATOMS=649,650

coordNa: COORDINATION GROUPA=Na GROUPB=O SWITCH={RATIONAL D_0=2.2 R_0=1.0 NN=4 MM=12}   # within a radius of roughly 3A

# define an upper_wall to keep the ions reasonably close
uwall: UPPER_WALLS ...
ARG=dist
AT=9.0
KAPPA=2000.0
... 

PYTORCH_GNN ...
  SYSTEM_SELECTION=sys
  ENVIRONMENT_SELECTION=env
  MODEL=model.pt
  STRUCTURE=NaCl.pdb
  LABEL=gnn
  NL_STRIDE=100
  BUFFER=3.0
... PYTORCH_GNN

opes: OPES_METAD ...
  ARG=gnn.node-0
  PACE=500
  SIGMA=0.2
  BARRIER=20
  TEMP=300
...

PRINT ARG=dist,coordNa,gnn.* STRIDE=100 FILE=colvar.dat

